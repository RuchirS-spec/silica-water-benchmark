# 1. Initialization & Logging
log generate_reax.log
units real          # CRITICAL: ReaxFF requires real units (time in fs, energy in kcal/mol)
boundary p p p
atom_style full

# 2. Box and Atoms
region box block -18.0 18.0 -9.0 9.0 -9.0 9.0
create_box 2 box
labelmap atom 1 Si 2 O
mass Si 28.0855
mass O 15.9994
create_atoms Si random 240 5802 box overlap 2.0 maxtry 500
create_atoms O random 480 1072 box overlap 2.0 maxtry 500

# 3. ReaxFF Force Field & Charge Equilibration
pair_style reaxff NULL
pair_coeff * * ffield.reax.SiOH Si O
fix qeq all qeq/reaxff 1 0.0 10.0 1.0e-6 reaxff

# 4. Output & Visualization (4x Multiplier applied for 0.25fs timestep)
dump ovito_dump all custom 1000 generate_traj.lammpstrj id type element x y z
dump_modify ovito_dump element Si O

thermo 1000
thermo_style custom step temp etotal vol density

# 5. Annealing Procedure (4x Multiplier applied to all runs)
velocity all create 6000 8289 rot yes dist gaussian

# Melt at 6000K (Notice Tdamp is 100.0 now)
fix mynvt all nvt temp 6000 6000 100.0
timestep 0.25       # CRITICAL: ReaxFF requires a much smaller timestep (0.25 fs)
run 40000

# Cool to 300K
fix mynvt all nvt temp 6000 300 100.0
run 120000

unfix mynvt

# Equilibrate at 300K and 1 atm (Notice Pdamp is 1000.0 now)
fix mynpt all npt temp 300 300 100.0 aniso 1 1 1000.0
run 40000

write_data generate.data
