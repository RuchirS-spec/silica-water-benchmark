# MACE Potential — Structure Generation (Melt-Quench)
# Mirrors the Vashishta/ReaxFF pipeline using the MACE-MP-0 foundation model

# 1. Initialization & Logging
echo both
log generate_mace.log
units metal              # MACE uses metal units (eV, Å, ps)
boundary p p p
atom_style atomic        # MACE operates on bare atomic positions
atom_modify map yes      # Required for MACE neighbor graph construction
newton on                # Required for MACE

# 2. Box and Atoms (identical geometry to Vashishta/ReaxFF)
region box block -18.0 18.0 -9.0 9.0 -9.0 9.0
create_box 2 box
labelmap atom 1 Si 2 O
mass Si 28.0855
mass O 15.9994
create_atoms Si random 240 5802 box overlap 2.0 maxtry 500
create_atoms O random 480 1072 box overlap 2.0 maxtry 500

# 3. MACE Force Field
pair_style mace no_domain_decomposition
pair_coeff * * MACE_SiOH.model Si O

# 4. Output & Visualization
dump ovito_dump all custom 250 generate_traj.lammpstrj id type element x y z
dump_modify ovito_dump element Si O

thermo 50
thermo_style custom step temp pe etotal press vol density

# 5. Relax initial close contacts before dynamics
#    MACE produces extreme forces for overlapping atoms — minimize first
timestep 0.001           # 1 fs timestep (standard for MACE with metal units)

minimize 1.0e-4 1.0e-6 1000 10000

# 5b. Gentle push-apart with limited displacement (0.1 Å max per step)
velocity all create 300 8289 rot yes dist gaussian
fix nvelim all nve/limit 0.1
run 1000
unfix nvelim

# 6. Annealing Procedure (same physical time as Vashishta: 50 ps total)

# Stage 1: Melt at 6000 K — 10 ps
velocity all create 6000 8289 rot yes dist gaussian
fix mynvt all nvt temp 6000 6000 0.1
run 10000

# Stage 2: Cool 6000 → 300 K — 30 ps
fix mynvt all nvt temp 6000 300 0.1
run 30000

unfix mynvt

# Stage 3: Equilibrate at 300 K, 1 atm (NPT) — 10 ps
fix mynpt all npt temp 300 300 0.1 aniso 1 1 1
run 10000

write_data generate.data
